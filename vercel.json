{
  "outputDirectory": "frontend/public",
  "framework": null,

  "functions": {
    "api/index.py": {
      "maxDuration": 30
    }
  },

  "redirects": [
    { "source": "/index.html",        "destination": "/",               "permanent": true },
    { "source": "/onboarding.html",   "destination": "/onboarding",     "permanent": true },
    { "source": "/privacy-policy.html","destination": "/privacy-policy", "permanent": true },
    { "source": "/terms-of-service.html","destination": "/terms-of-service","permanent": true }
  ],

  "rewrites": [
    { "source": "/api/:path*",                                          "destination": "/api/index.py"                                          },
    { "source": "/onboarding",                                          "destination": "/onboarding.html"                                       },
    { "source": "/privacy-policy",                                      "destination": "/privacy-policy.html"                                   },
    { "source": "/terms-of-service",                                    "destination": "/terms-of-service.html"                                 },
    { "source": "/maryland-contractors",                                "destination": "/maryland-contractors.html"                             },
    { "source": "/blog",                                                "destination": "/blog/index.html"                                       },
    { "source": "/blog/missed-call-text-back-for-contractors",          "destination": "/blog/missed-call-text-back-for-contractors.html"       },
    { "source": "/blog/how-to-rank-higher-google-maps-contractor",      "destination": "/blog/how-to-rank-higher-google-maps-contractor.html"   },
    { "source": "/blog/why-contractors-need-a-professional-website",    "destination": "/blog/why-contractors-need-a-professional-website.html" },
    { "source": "/(.*)",                                                "destination": "/index.html"                                            }
  ]
}
